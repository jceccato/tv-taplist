# Copy to .env and edit. docker compose reads this automatically.
# Tip: scripts/setup.sh fills this in for you interactively.

# Required: password for the /admin interface.
ADMIN_PASSWORD=changeme

# Required: long random string used to sign session cookies.
# Generate one, e.g.:  openssl rand -hex 32
SESSION_SECRET=change-this-long-random-secret

# Container timezone (IANA name). Drives archive timestamps + daily cleanup.
TZ=Australia/Sydney

# Host port for the web UI (mapped to the container's 8080).
PORT=8080

# Host directory mapped to /data. config.json, taps/ and old_beers/ live here as
# plain text + images, so the server admin can read them directly. Relative paths
# are resolved next to docker-compose.yml.
DATA_DIR_HOST=./taplist_data

# IP(s) of your trusted reverse proxy. ONLY these are allowed to set
# X-Forwarded-For / X-Forwarded-Proto. Comma-separate multiple.
# For the Docker default bridge, the proxy often appears as 172.17.0.1.
FORWARDED_ALLOW_IPS=127.0.0.1

# Host user/group that owns the data directory (so /data stays writable).
PUID=1000
PGID=1000

# Set true on a fresh data directory to seed demo taps for an offline demo.
DEMO_MODE=false

# Optional: Brewfather credentials via environment instead of the admin UI, so
# the API key is never written to config.json on disk. When both are set the
# admin fields are locked and show "managed via environment". Leave blank to
# enter them in /admin instead.
BREWFATHER_USER_ID=
BREWFATHER_API_KEY=

# Optional: minutes between Brewfather syncs (default 15). The paginated
# complete=True fetch stays well under the 500 calls/hour API limit.
SYNC_INTERVAL_MINUTES=15
