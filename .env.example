# Copy to .env and edit. docker-compose reads this automatically.

# Required: password for the /admin interface.
ADMIN_PASSWORD=changeme

# Required: long random string used to sign session cookies.
# Generate one, e.g.:  openssl rand -hex 32
SESSION_SECRET=change-this-long-random-secret

# Container timezone (IANA name). Drives archive timestamps + daily cleanup.
TZ=Australia/Sydney

# IP(s) of your trusted reverse proxy. ONLY these are allowed to set
# X-Forwarded-For / X-Forwarded-Proto. Comma-separate multiple.
# For the Docker default bridge, the proxy often appears as 172.17.0.1.
FORWARDED_ALLOW_IPS=127.0.0.1

# Host user/group that owns the data volume (so /data stays writable).
PUID=1000
PGID=1000

# Set true on a fresh volume to seed demo taps for an offline screenshot/demo.
DEMO_MODE=false
